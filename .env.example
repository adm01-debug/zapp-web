# ==============================================================================
# CONFIGURAÇÃO DE AMBIENTE - PRODUÇÃO
# ==============================================================================
# Copie este arquivo para .env e preencha com os valores reais

# SUPABASE
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# BITRIX24 (opcional - se integrado)
VITE_BITRIX_WEBHOOK_URL=https://promobrindes.bitrix24.com.br/rest/1/seu-webhook/

# APP CONFIG
VITE_APP_NAME=Sistema Empresarial
VITE_APP_ENV=production

# FEATURES FLAGS
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# ==============================================================================
# IMPORTANTE: Nunca commitar o arquivo .env com valores reais!
# ==============================================================================

# External CRM Database (for Contact 360° enrichment)
VITE_EXTERNAL_SUPABASE_URL=https://your-external-project.supabase.co
VITE_EXTERNAL_SUPABASE_ANON_KEY=your-external-anon-key
